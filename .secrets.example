# Copy this file to `.secrets` and fill in your real credentials.
# `.secrets` is gitignored — never commit real values.

TIMENOTES_EMAIL=you@example.com
TIMENOTES_PASSWORD=your_password

# Optional: pre-select a specific workspace.
# TIMENOTES_ACCOUNT_ID=

# Optional: skip /sessions login by providing a pre-obtained token.
# TIMENOTES_TOKEN=

# Optional: override the API base (default https://api.timenotes.io/v1).
# TIMENOTES_BASE_URL=
